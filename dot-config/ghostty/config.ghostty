# Theme (Run 'ghostty +list-themes' to see options)
theme = Nord Wave

# Font settings
font-family = "JetBrainsMono Nerd Font"
font-size = 11
font-thicken = true

# Window appearance
background-opacity = 0.9
background-blur = 20
window-padding-x = 10
window-padding-y = 10
window-padding-balance = true

# Mouse and Cursor
cursor-style = bar
mouse-hide-while-typing = true

